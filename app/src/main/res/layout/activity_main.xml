<?xml version="1.0" encoding="utf-8"?>
<!--
  OTP Share — Main Activity Layout
  A simple setup screen with server URL, device ID, and password fields.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#0A0A1A"
    android:gravity="center_horizontal">

    <!-- App Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📱 OTP Share"
        android:textSize="28sp"
        android:textColor="#A78BFA"
        android:textStyle="bold"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Forward SMS to your PC"
        android:textSize="14sp"
        android:textColor="#6A6A8E"
        android:layout_marginBottom="32dp"/>

    <!-- Status Indicator -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="○ Not configured"
        android:textSize="16sp"
        android:textColor="#EF4444"
        android:textAlignment="center"
        android:padding="12dp"
        android:background="#1A1A2E"
        android:layout_marginBottom="24dp"/>

    <!-- Server URL Input -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SERVER URL"
        android:textColor="#A0A0CC"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/et_server_url"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="http://your-server-ip:3000"
        android:textColor="#F0F0FF"
        android:textColorHint="#6A6A8E"
        android:background="#111127"
        android:padding="14dp"
        android:textSize="15sp"
        android:inputType="textUri"
        android:layout_marginBottom="16dp"/>

    <!-- Device ID Input -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DEVICE ID"
        android:textColor="#A0A0CC"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/et_device_id"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. myphone"
        android:textColor="#F0F0FF"
        android:textColorHint="#6A6A8E"
        android:background="#111127"
        android:padding="14dp"
        android:textSize="15sp"
        android:inputType="text"
        android:layout_marginBottom="16dp"/>

    <!-- Password Input -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="PASSWORD"
        android:textColor="#A0A0CC"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/et_password"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Your password"
        android:textColor="#F0F0FF"
        android:textColorHint="#6A6A8E"
        android:background="#111127"
        android:padding="14dp"
        android:textSize="15sp"
        android:inputType="textPassword"
        android:layout_marginBottom="24dp"/>

    <!-- Save Button -->
    <Button
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💾 Save Settings"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textAllCaps="false"
        android:backgroundTint="#6366F1"
        android:padding="14dp"
        android:layout_marginBottom="12dp"/>

    <!-- Toggle Button -->
    <Button
        android:id="@+id/btn_toggle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="▶ Start Forwarding"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textAllCaps="false"
        android:backgroundTint="#10B981"
        android:padding="14dp"
        android:layout_marginBottom="12dp"/>

    <!-- Test Connection Button -->
    <Button
        android:id="@+id/btn_test"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📡 Test Connection"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textAllCaps="false"
        android:backgroundTint="#F59E0B"
        android:padding="14dp"
        android:layout_marginBottom="24dp"/>

    <!-- Logs Section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="LOGS"
        android:textColor="#A0A0CC"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginBottom="6dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="#0F0F1A"
        android:padding="8dp"
        android:layout_marginBottom="24dp">
        <TextView
            android:id="@+id/tv_logs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="App ready..."
            android:textColor="#8BBAA7"
            android:textSize="12sp"
            android:fontFamily="monospace"/>
    </ScrollView>

    <!-- Help Text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ℹ️ This app runs in the background and automatically forwards incoming SMS messages to your PC via the server."
        android:textColor="#6A6A8E"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.3"
        android:textAlignment="center"
        android:padding="12dp"/>

</LinearLayout>
